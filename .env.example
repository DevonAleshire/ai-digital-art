# Environment: "development" or "production"
NODE_ENV=development

# OpenAI — platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Twilio — console.twilio.com (Auth Token required for webhook signature validation)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# The public base URL for this server (no trailing slash)
# During Mac testing: paste your ngrok HTTPS URL here, e.g. https://abc123.ngrok-free.app
# On Raspberry Pi: your Cloudflare Tunnel URL, e.g. https://your-name.trycloudflare.com
WEBHOOK_BASE_URL=https://your-tunnel-url-here

PORT=3000

# Supabase — supabase.com > project > Settings > Data API
# Use the SECRET "service_role" key — this runs server-side only, never in the browser
# Dev project:  ai-digital-art-dev
# Prod project: ai-digital-art-prod
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cron schedule for image generation (node-cron syntax)
# Dev default (every minute):        */1 * * * *
# Production 3x/day (8am,12pm,6pm):  0 8,12,18 * * *
# Production 1x/day (9am):           0 9 * * *
CRON_SCHEDULE=*/1 * * * *
